# A.won Pinterest Automation — Environment Variables
# Copy this file to .env for local development.
# Never commit the .env file. All values below are required.

GOOGLE_SERVICE_ACCOUNT_JSON=your-service-account-json-here
PINTEREST_CLIENT_ID=your-pinterest-client-id-here
PINTEREST_CLIENT_SECRET=your-pinterest-client-secret-here
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here
